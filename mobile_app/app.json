{
  "expo": {
    "name": "Orava",
    "slug": "orava",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "orava",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.orava.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Orava utilise la caméra pour les photos de profil.",
        "NSPhotoLibraryUsageDescription": "Orava accède à ta galerie pour les photos de profil."
      }
    },
    "android": {
      "package": "com.orava.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
