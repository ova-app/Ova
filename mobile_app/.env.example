# Copier ce fichier en `.env` (gitignored) et remplir avec les vraies valeurs.
# Les clés se demandent au propriétaire du projet — JAMAIS commitées.

# Supabase — projet Orava (région Frankfurt)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...votre_anon_key

# PostHog — analytics (EU)
EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ⚠️ NE PAS mettre la clé SUPABASE_SERVICE_ROLE_KEY ici.
# Elle bypass toute la RLS et n'a rien à faire dans une app cliente.
# Usage serveur/admin uniquement, hors de ce dossier.
